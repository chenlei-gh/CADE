// <DialogClassName> 对话框字符串（简体中文）
// 合并到 framework 共享 catalog: Simplified_Chinese/<FrameworkName>.CATNls
//
// NOTE: 本文件必须 GBK 编码（CATIA V5 按系统代码页读 catalog，官方
// Simplified_Chinese/*.CATNls 均为 GBK）；CADE 生成时已自动处理。
// 文件名与英文版相同，仅所在语言子目录不同（CATIA 按运行语言自动查找）。

// 对话框窗口标题
<DialogClassName>.Title = "<DialogClassName>";

// 控件文本
<DialogClassName>.LabelId = "值:";
