// Resource file for <CommandClassName> (Simplified Chinese)
// File: Simplified_Chinese/<FrameworkName>.CATNls
//
// NOTE: 文件名与英文版相同，仅所在语言子目录不同（CATIA 按运行语言自动查找）。

// 命令标题（工具栏提示）
<CommandHeaderName>.Title = "<CommandTitle>";
<CommandHeaderName>.ShortHelp = "执行 <CommandClassName>";
<CommandHeaderName>.LongHelp = "执行 <CommandClassName> 命令。";
<CommandHeaderName>.Help = "<CommandClassName>";

// 命令提示（交互过程中显示）
<CommandClassName>.State1.Prompt = "选择第一个元素";
<CommandClassName>.State2.Prompt = "选择第二个元素";
<CommandClassName>.State3.Prompt = "正在处理...";

// 错误消息
<CommandClassName>.ErrorNoSelection = "未选择元素";
<CommandClassName>.ErrorInvalidSelection = "元素类型无效";
<CommandClassName>.ErrorProcessing = "处理失败";

// 成功消息
<CommandClassName>.Success = "操作成功完成";
