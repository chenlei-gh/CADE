// Alternative states (optional)
// <CommandHeaderName>.Icon.Pressed = "I_<CommandIconName>P";
// <CommandHeaderName>.Icon.Focused = "I_<CommandIconName>F";

// Icon categories (for toolbar customization)
<CommandHeaderName>.Category = "MfgToolsCommands";
