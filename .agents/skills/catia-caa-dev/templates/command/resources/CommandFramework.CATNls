// Resource file for <CommandClassName> (English / default)
// File: <FrameworkName>.CATNls

// Command title (shown in toolbar tooltip)
<CommandHeaderName>.Title = "<CommandTitle>";
<CommandHeaderName>.ShortHelp = "Execute <CommandClassName>";
<CommandHeaderName>.LongHelp = "Execute <CommandClassName> command.";
<CommandHeaderName>.Help = "<CommandClassName>";

// Command prompts (shown during interaction)
<CommandClassName>.State1.Prompt = "Select first element";
<CommandClassName>.State2.Prompt = "Select second element";
<CommandClassName>.State3.Prompt = "Processing...";

// Error messages
<CommandClassName>.ErrorNoSelection = "No element selected";
<CommandClassName>.ErrorInvalidSelection = "Invalid element type";
<CommandClassName>.ErrorProcessing = "Processing failed";

// Success messages
<CommandClassName>.Success = "Operation completed successfully";
